# Required in production (omit BUDDYPLAN_DEV or set to 0)
SESSION_SECRET_KEY=
TOKEN_PEPPER=

# Optional dev mode: allows ephemeral/dev-only secrets (local development only)
# BUDDYPLAN_DEV=1

DATABASE_PATH=/data/buddyplan.db
TZ=Europe/Amsterdam

# Optional first-run admin (skips /setup)
# BUDDYPLAN_ADMIN_USERNAME=
# BUDDYPLAN_ADMIN_PASSWORD=
# BUDDYPLAN_ADMIN_NAME=Admin
